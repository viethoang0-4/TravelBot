# =============================
# TravelBot Backend - Environment Variables
# =============================

# [Required] Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# [Optional] Tavily Search API (for Hidden Gems / real-time search)
# Get free key at https://tavily.com
TAVILY_API_KEY=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

# [Optional] OpenWeatherMap API (for weather-aware planning)
# Get free key at https://openweathermap.org/api
OPENWEATHER_API_KEY=

# [Optional] Database URL - leave empty to use JSON mock DB
# Format: postgresql+asyncpg://user:password@localhost:5432/travelbot
DATABASE_URL=

# App
DEBUG=false
